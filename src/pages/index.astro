---
import Base from "../layouts/Base.astro";
import { STORY_EN, SOCIALS, CATEGORIES_EN, ALON_SERIES_EN } from "../../data/en-content.mjs";
import site from "../../data/site-data.json";
import "../styles/home.css";

const counts = site.counts;
const curated = site.curated;
const music = site.music;
const alonim = site.alonim;
const tfilot = site.tfilot;

// group curated by english category
const byCat = {};
for (const v of curated) (byCat[v.category] ||= []).push(v);

const nf = (n) => new Intl.NumberFormat("en-US").format(n);
const nav = [
  ["#story", "The Story"], ["#torah", "Torah"], ["#niggunim", "Niggunim"],
  ["#alonim", "Weekly Writings"], ["#tefillos", "Tefillos"], ["#follow", "Follow"],
];
const waEn = SOCIALS.find((s) => s.key === "whatsapp-en")?.url || "#follow";
const TICKER = [
  "New shiurim added every week",
  "Every video — watch, listen, download, keep",
  `${nf(counts.library)} shiurim, gathered into one home`,
  "His tefillos — free to read, download and print",
  "Join the English WhatsApp group",
  "Niggunim for the road and the quiet hour",
];
---
<Base>
  <div id="sprog" aria-hidden="true"></div>
  <!-- ===== HEADER ===== -->
  <header class="site-head">
    <div class="wrap head-in">
      <a class="brand" href="/">
        <img class="brand-mark" src="/favicon.svg" alt="" width="38" height="38" />
        <span class="brand-txt"><b>The Yanuka</b><small>Torah in English</small></span>
      </a>
      <nav class="head-nav">
        {nav.map(([h, l]) => <a href={h}>{l}</a>)}
      </nav>
      <div class="head-cta">
        <button class="icon-btn" id="hy-lib-btn" aria-label="My Library" title="My Library">♥<span id="hy-lib-count" class="lib-badge"></span></button>
        <button class="icon-btn" onclick="toggleTheme()" aria-label="Toggle light and dark">☾</button>
        <a class="btn btn-gold sm" href="#torah">Explore</a>
      </div>
    </div>
  </header>

  <!-- ===== ANNOUNCEMENT TICKER ===== -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[...TICKER, ...TICKER].map((t) => <span class="tk"><i>✦</i>{t}</span>)}
    </div>
  </div>

  <!-- ===== TIMELY BANNER (populated from the CDN when there's a moment to hold) ===== -->
  <div id="timelyBanner" class="timely" hidden></div>

  <!-- ===== MOBILE SECTION NAV (phones only — the way around the long scroll) ===== -->
  <nav class="mnav" id="mnav" aria-label="Jump to section">
    {[["#sparks","✦","Sparks"],["#recent","✨","New"],["#torah","📖","Torah"],["#niggunim","🎵","Niggunim"],["#alonim","📜","Weekly"],["#tefillos","🕯","Tefillos"],["#story","✦","Story"],["#app","📲","App"],["#follow","💬","Follow"]].map(([h, ic, l]) => (
      <a href={h}><i>{ic}</i>{l}</a>
    ))}
  </nav>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg" id="heroBg"></div>
    <div class="hero-portrait kenburns" style="background-image:url('/img/main-3.jpeg')"></div>
    <div class="hero-veil" id="heroVeil"></div>
    <canvas id="sparks" aria-hidden="true"></canvas>
    <div class="wrap hero-in" id="heroIn">
      <p class="eyebrow reveal">The official Torah of HaGaon Rav Shlomo Yehuda shlit”a</p>
      <h1 class="hero-title reveal">The Yanuka<span class="dot">.</span><br /><em>in English.</em></h1>
      <p class="hero-quote reveal">{STORY_EN.epigraph}</p>
      <div class="hero-cta reveal">
        <a class="btn btn-gold" href="#torah">▸ Watch the Shiurim</a>
        <button class="btn btn-spark" data-sparks title="Short clips, shortest first — swipe through">✦ Sparks</button>
        <a class="btn btn-ghost" href="#follow">Follow &amp; Subscribe</a>
      </div>
      <div class="hero-stats reveal">
        <div><b data-count={counts.library}>0</b><span>videos, indexed</span></div>
        <div><b data-count={counts.alonim}>0</b><span>weekly writings</span></div>
        <div><b data-count={counts.tfilot + counts.music}>0</b><span>tefillos &amp; niggunim</span></div>
        <div><b>1</b><span>place, all of it</span></div>
      </div>
    </div>
    <a class="scroll-hint" href="#promise" aria-label="Scroll">⌄</a>
  </section>

  <!-- ===== PROMISE / MOAT ===== -->
  <section class="promise" id="promise">
    <div class="wrap promise-in">
      <div class="promise-card card">
        <span class="pc-ic">🌍</span>
        <h3>Everything, gathered into one home</h3>
        <p>His Torah is scattered in a thousand places. We tracked down every shiur we could find, <b>downloaded and kept every one</b>, and organized them into a single English home — so you never have to hunt again, and it's always here.</p>
      </div>
      <div class="promise-card card">
        <span class="pc-ic">⬇︎</span>
        <h3>Watch or download — audio &amp; video</h3>
        <p>Every shiur, every niggun, ready to stream, or download in <b>video</b> for the screen or <b>audio-only</b> for the car and the walk. It's already saved and waiting.</p>
      </div>
      <div class="promise-card card">
        <span class="pc-ic">✦</span>
        <h3>In English, at last</h3>
        <p>The Torah, the story, the weekly writings and the tefillos — organized and presented in English, the easiest way possible, so the Yanuka's light reaches everyone.</p>
      </div>
    </div>
  </section>

  <!-- ===== MISSION (scroll-lit text) ===== -->
  <section class="mission" id="mission">
    <div class="wrap mission-in">
      <p class="eyebrow reveal">Why this home exists</p>
      <p class="hl" id="hlText">He sits and learns, and the world comes to listen. We gathered <b>every shiur</b>, every niggun, every page he has given — into <b>one home, in English</b> — so his Torah can reach you, <b>wherever you are</b>.</p>
    </div>
  </section>

  <!-- ===== MOMENTS MARQUEE ===== -->
  <section class="moments" aria-label="Moments from the shiurim">
    <div class="mq" id="mq1"></div>
    <div class="mq mq-rev" id="mq2"></div>
  </section>

  <!-- ===== RECENTLY ADDED (fed live from the CDN by the 12-hour sweep) ===== -->
  <section class="recent" id="recent">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Fresh · swept in twice a day, automatically</p>
        <h2>Recently <span class="au">Added</span></h2>
        <p class="sec-sub">The newest shiurim from every channel — found, saved, and filed here the moment they appear.</p>
      </div>
      <div id="recentGrid" class="lib-grid"></div>
    </div>
  </section>

  <!-- ===== STORY ===== -->
  <section class="story" id="story">
    <div class="wrap story-in">
      <div class="story-media reveal">
        <div class="tviewer" id="tviewer" data-src="/data/tefillot-latest.json">
          <div class="tv-head"><span class="eyebrow">His Tefillos</span><b>The latest collection — swipe through, download, or print</b></div>
          <div class="tv-stage">
            <button class="tv-nav tv-prev" aria-label="Previous page">‹</button>
            <div class="tv-track" id="tvTrack"></div>
            <button class="tv-nav tv-next" aria-label="Next page">›</button>
          </div>
          <div class="tv-foot">
            <span class="tv-count" id="tvCount">—</span>
            <a class="btn btn-gold sm" id="tvDownload" href="#" download>⬇︎ Download</a>
            <button class="btn btn-ghost sm" id="tvPrint">🖨 Print</button>
          </div>
        </div>
        <div class="story-badge">{STORY_EN.name}</div>
      </div>
      <div class="story-txt">
        <p class="eyebrow reveal">The Story</p>
        <h2 class="reveal">{STORY_EN.title}</h2>
        {STORY_EN.sections.map((s) => (
          <div class="story-sec reveal">
            <h3>{s.heading}</h3>
            {s.paragraphs.map((p) => <p>{p}</p>)}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TORAH LIBRARY ===== -->
  <section class="torah" id="torah">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">The Library · every shiur, in one place</p>
        <h2>The Torah <span class="au">of the Yanuka</span></h2>
        <p class="sec-sub">All <b>{nf(counts.library)}</b> videos we found across every channel — searchable, watchable, downloadable in audio or video.</p>
      </div>

      <!-- featured curated rows -->
      {Object.entries(byCat).map(([c, vids]) => (
        <div class="row reveal">
          <div class="row-head"><h3>{c}</h3><span>{CATEGORIES_EN[Object.keys(CATEGORIES_EN).find(k=>CATEGORIES_EN[k].en===c)]?.sub || ""}</span></div>
          <div class="row-scroll">
            {vids.map((v) => (
              <article class="vcard" data-id={v.id}>
                <button class="vthumb" data-watch={v.id} data-title={v.he} aria-label={"Play " + v.en}>
                  <img data-thumb={v.id} alt="" loading="lazy" />
                  <span class="play">▸</span>
                </button>
                <div class="vmeta">
                  <p class="vtitle">{v.en}</p>
                  <p class="vhe" dir="rtl">{v.he}</p>
                  <div class="vacts">
                    <button class="chip" data-watch={v.id} data-title={v.he}>Watch</button>
                    <button class="chip" data-listen={v.id} data-title={v.he}>Listen</button>
                    <button class="heart" data-save={v.id} data-title={v.he} title="Save">♡</button>
                    <button class="chip addpl" data-addpl={v.id} data-title={v.he} title="Add to playlist">＋</button>
                    <div class="dl">
                      <button class="chip dl-btn">↓</button>
                      <div class="dl-menu">
                        <a data-dl={v.id} data-fmt="video">🎬 Video (MP4)</a>
                        <a data-dl={v.id} data-fmt="audio">🎧 Audio (MP3)</a>
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}

      <!-- full searchable index -->
      <div class="lib reveal">
        <div class="lib-controls">
          <input id="libSearch" type="search" placeholder="Search all shiurim by title (Hebrew or English)…" autocomplete="off" />
          <select id="libChannel"><option value="">All channels</option></select>
          <span id="libCount" class="lib-count"></span>
        </div>
        <div id="libGrid" class="lib-grid"></div>
        <button id="libMore" class="btn btn-ghost lib-more" hidden>Show more</button>
      </div>
    </div>
  </section>

  <!-- ===== NIGGUNIM ===== -->
  <section class="niggunim" id="niggunim">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Niggunim · melodies of the soul</p>
        <h2>Niggunei <span class="au">HaYanuka</span></h2>
        <p class="sec-sub">The melodies he plays and composes — for the heart, for the road, for the quiet hour.</p>
      </div>
      <div class="nig-grid">
        {music.map((m) => (
          <button class="nig" data-watch={m.mid} data-title={m.he}>
            <img data-thumb={m.mid} alt="" loading="lazy" />
            <span class="nig-play">▸</span>
            <div class="nig-meta"><b>{m.en}</b><small dir="rtl">{m.he}</small></div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ALONIM ===== -->
  <section class="alonim" id="alonim">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Weekly Writings · {ALON_SERIES_EN}</p>
        <h2>The Weekly <span class="au">Alonim</span></h2>
        <p class="sec-sub"><b>{counts.alonim}</b> weekly Torah sheets from the Rav's table — free to read and download.</p>
      </div>
      <div class="alon-controls">
        <input id="alonSearch" type="search" placeholder="Search by parashah…" autocomplete="off" />
      </div>
      <div id="alonGrid" class="alon-grid"></div>
      <button id="alonMore" class="btn btn-ghost lib-more" hidden>Show more</button>
    </div>
  </section>

  <!-- ===== TEFILLOS ===== -->
  <section class="tefillos" id="tefillos">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Tefillos &amp; Segulos</p>
        <h2>Prayers <span class="au">Composed by the Yanuka</span></h2>
        <p class="sec-sub">Tefillos and segulos he composed — for healing, parnassah, a zivug, children, and more.</p>
      </div>
      <div class="tef-grid">
        {tfilot.map((t) => (
          <a class="tef card reveal" href={t.pdf} target="_blank" rel="noopener">
            <span class="tef-cover"><img loading="lazy" src={`https://hayanuka-media.nyc3.cdn.digitaloceanspaces.com/covers/${t.id}.jpg`} alt="" onerror="this.closest('.tef').classList.add('no-cover')" /></span>
            <span class="tef-ic">{t.category === "Segulos" ? "✦" : "🕯"}</span>
            <div><b>{t.en}</b><small dir="rtl">{t.he}</small></div>
            <span class="tef-dl">Download ↓</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== GET THE APP ===== -->
  <section class="getapp" id="app">
    <div class="wrap getapp-in">
      <div class="getapp-txt reveal">
        <p class="eyebrow">The App · take the whole hub with you</p>
        <h2>Install the <span class="au">Yanuka app</span></h2>
        <p class="sec-sub">Put all {new Intl.NumberFormat("en-US").format(counts.library)} shiurim, the niggunim and the weekly writings on your home screen — one tap, works offline, no App Store needed.</p>
        <div class="getapp-cta">
          <button id="installBtn" class="btn btn-gold" hidden>⬇︎ Install the App</button>
          <a id="apkBtn" class="btn btn-gold" href="/app/hayanuka.apk" download hidden>Download for Android (APK)</a>
          <button id="iosBtn" class="btn btn-gold">Add to iPhone / iPad</button>
          <a class="btn btn-ghost" href="#torah">Open in browser</a>
        </div>
        <p id="installHint" class="getapp-hint"></p>
      </div>
      <div class="getapp-phone reveal" aria-hidden="true">
        <div class="phone">
          <div class="phone-scr">
            <div class="phone-top"><img class="phone-mark" src="/favicon.svg" alt="" width="26" height="26" /><b>The Yanuka</b></div>
            <div class="phone-hero"><span>▸</span></div>
            <div class="phone-rows"><i></i><i></i><i></i><i></i></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOLLOW ===== -->
  <section class="follow" id="follow">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Follow &amp; Subscribe</p>
        <h2>Stay connected <span class="au">to the Yanuka</span></h2>
        <p class="sec-sub">Every channel and group, in one place. Subscribe, follow, and support the mosdos.</p>
      </div>
      <div class="soc-grid">
        {SOCIALS.map((s) => (
          <a class="soc card reveal" href={s.url} target="_blank" rel="noopener">
            <div class="soc-l"><b>{s.label}</b><small>{s.handle}</small></div>
            <span class="soc-cta">{s.cta} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA BAND ===== -->
  <section class="ctaband">
    <div class="wrap ctaband-in reveal">
      <p class="cb-eyebrow">Take it with you</p>
      <h2>His Torah — with you, everywhere.</h2>
      <p class="cb-sub">Install the app, join the group, and the shiurim travel with you — offline, forever.</p>
      <div class="cb-cta">
        <a class="btn btn-dark" href="#app">⬇︎ Install the app</a>
        <a class="btn btn-dark" href={waEn} target="_blank" rel="noopener">💬 Join the WhatsApp group</a>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="site-foot">
    <div class="wrap foot-in">
      <div>
        <div class="brand"><img class="brand-mark" src="/favicon.svg" alt="" width="38" height="38" /><span class="brand-txt"><b>hayanuka.life</b><small>the Torah of the Yanuka, in English</small></span></div>
        <p class="foot-note">An English home for the Torah, niggunim and tefillos of HaGaon Rav Shlomo Yehuda Beeri shlit”a. All content belongs to the Yanuka and his mosdos, brought here with love and with links back to the official channels.</p>
      </div>
      <div class="foot-links">
        <a href="https://hayanuka.com" target="_blank" rel="noopener">Official Site (Hebrew) →</a>
        <a href="https://hayanuka.com/he/donate" target="_blank" rel="noopener">Support the Mosdos →</a>
      </div>
    </div>
    <div class="wrap foot-bottom"><span>© {new Date().getFullYear()} · Made for the spreading of Torah · לזכות הרבים</span></div>
  </footer>

  <!-- ===== PLAYER MODAL ===== -->
  <div id="player" class="player" hidden>
    <button class="player-close" aria-label="Close">✕</button>
    <div class="player-box"><div class="player-frame" id="playerFrame"></div></div>
  </div>

  <!-- ===== TOAST ===== -->
  <div id="toast" class="toast" hidden></div>

  <!-- ===== ADD-TO-PHONE SHEET ===== -->
  <div id="iosSheet" class="iosheet" hidden>
    <div class="is-card">
      <button class="is-close" id="iosClose" aria-label="Close">✕</button>
      <img src="/favicon.svg" alt="" width="56" height="56" />
      <b>Put the Yanuka on your Home Screen</b>
      <ol>
        <li><span class="is-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m8 7 4-4 4 4"/><rect x="4" y="11" width="16" height="10" rx="2" fill="none"/></svg></span><span class="is-t">In <b>Safari</b>, tap the <b>Share</b> button</span></li>
        <li><span class="is-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="4" y="4" width="16" height="16" rx="4" fill="none"/><path d="M12 8.5v7M8.5 12h7"/></svg></span><span class="is-t">Scroll down, choose <b>Add to Home Screen</b></span></li>
        <li><span class="is-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg></span><span class="is-t">Tap <b>Add</b> — it opens full-screen and works offline</span></li>
      </ol>
      <p id="iosNote" class="is-note"></p>
    </div>
  </div>

  <script is:inline src="/player.js" defer></script>
  <script is:inline src="/app.js" defer></script>

  <script>
    // State-of-the-art motion layer — GSAP ScrollTrigger + ambient canvas + micro-interactions.
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fine = matchMedia("(hover:hover) and (pointer:fine)").matches;

    if (!reduced) {
      gsap.registerPlugin(ScrollTrigger);
      // gold scroll progress bar
      gsap.to("#sprog", { scaleX: 1, ease: "none", scrollTrigger: { start: 0, end: "max", scrub: 0.3 } });
      // curated rows drift gently sideways as you scroll (alternating)
      gsap.utils.toArray(".torah .row").forEach((row, i) => {
        gsap.fromTo(row, { x: i % 2 ? 26 : -26 }, { x: i % 2 ? -14 : 14, ease: "none",
          scrollTrigger: { trigger: row, start: "top bottom", end: "bottom top", scrub: 0.6 } });
      });
      // niggunim + alonim tiles: staggered rise
      for (const sel of [".nig", ".alon"]) {
        ScrollTrigger.batch(sel, { start: "top 92%", once: true,
          onEnter: (els) => gsap.fromTo(els, { y: 28, opacity: 0, scale: 0.97 }, { y: 0, opacity: 1, scale: 1, duration: 0.7, stagger: 0.06, ease: "power3.out", overwrite: true }) });
      }
      // phone mockup leans in 3D with scroll
      const ph = document.querySelector(".phone");
      if (ph) gsap.fromTo(ph, { rotateY: -16, rotateX: 6 }, { rotateY: 10, rotateX: -4, ease: "none",
        scrollTrigger: { trigger: ph, start: "top bottom", end: "bottom top", scrub: 0.5 } });

      // ambient candle sparks in the hero (canvas)
      const cv = document.getElementById("sparks");
      if (cv) {
        const x = cv.getContext("2d"); const dpr = Math.min(2, devicePixelRatio || 1);
        let W, H, ps = [];
        const size = () => { W = cv.clientWidth; H = cv.clientHeight; cv.width = W * dpr; cv.height = H * dpr; x.setTransform(dpr, 0, 0, dpr, 0, 0); };
        size(); addEventListener("resize", size);
        const N = matchMedia("(max-width:820px)").matches ? 22 : 42;
        const mk = () => ({ x: Math.random() * W, y: H + 10 + Math.random() * 40, r: 0.6 + Math.random() * 1.8,
          vy: 0.12 + Math.random() * 0.35, vx: (Math.random() - 0.5) * 0.14, tw: Math.random() * Math.PI * 2, life: 0 });
        for (let i = 0; i < N; i++) { const p = mk(); p.y = Math.random() * H; ps[i] = p; }
        let vis = true;
        new IntersectionObserver((e) => (vis = e[0].isIntersecting)).observe(cv);
        (function tick() {
          requestAnimationFrame(tick); if (!vis) return;
          x.clearRect(0, 0, W, H);
          for (let i = 0; i < ps.length; i++) {
            const p = ps[i]; p.y -= p.vy; p.x += p.vx + Math.sin(p.tw + p.y * 0.012) * 0.08; p.tw += 0.02;
            if (p.y < -12) ps[i] = mk();
            const a = (0.25 + 0.55 * Math.abs(Math.sin(p.tw))) * Math.min(1, (H - p.y) / 120 + 0.4);
            x.beginPath(); x.arc(p.x, p.y, p.r, 0, 7);
            x.fillStyle = `rgba(228,196,130,${a * 0.5})`; x.shadowColor = "rgba(228,196,130,.8)"; x.shadowBlur = 8; x.fill(); x.shadowBlur = 0;
          }
        })();
      }
    }

    // cursor glow + magnetic gold buttons (desktop only)
    if (!reduced && fine) {
      const glow = document.createElement("div"); glow.id = "cursor-glow"; document.body.appendChild(glow);
      let gx = -400, gy = -400, tx = gx, ty = gy;
      addEventListener("mousemove", (e) => { tx = e.clientX; ty = e.clientY; }, { passive: true });
      (function g() { gx += (tx - gx) * 0.12; gy += (ty - gy) * 0.12; glow.style.transform = `translate(${gx - 170}px, ${gy - 170}px)`; requestAnimationFrame(g); })();
      document.querySelectorAll(".btn").forEach((b) => {
        b.addEventListener("mousemove", (e) => { const r = b.getBoundingClientRect();
          b.style.translate = `${(e.clientX - r.left - r.width / 2) * 0.12}px ${(e.clientY - r.top - r.height / 2) * 0.22}px`; });
        b.addEventListener("mouseleave", () => { b.style.translate = ""; });
      });
    }
  </script>
</Base>
